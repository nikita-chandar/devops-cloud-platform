name: Devops CD Pipeline

on:
 workflow_run:
   workflows:
     - Devops CI Pipeline
   types:
     - completed

jobs:

  deploy:
 
    runs-on: ubuntu-latest

    steps:

    - name: Deploy to EC2
      uses: appleboy/ssh-action@v1.0.3
    
    with:
      host: ${{ secrets.EC2_host}}
      username: ${{ secrets.EC2_USER }}
      key: ${{ secrets.EC2_SSH_KEY }}
 
    script: |
       cd devops-cloud-platform
       git pull

       docker stop devops-app || true
      
